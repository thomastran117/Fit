generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @db.VarChar(36)
  email         String   @unique @db.VarChar(255)
  passwordHash  String   @map("password_hash") @db.VarChar(255)
  firstName     String?  @map("first_name") @db.VarChar(255)
  lastName      String?  @map("last_name") @db.VarChar(255)
  role          String   @db.VarChar(50)
  emailVerified Boolean  @default(false) @map("email_verified")
  createdAt     DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.DateTime(6)
  devices       Device[]
  profile       Profile?
  postings      Posting[]
  postingReviews PostingReview[] @relation("PostingReviewAuthor")

  @@map("users")
}

model Profile {
  id                       String   @id @db.VarChar(36)
  userId                   String   @unique @map("user_id") @db.VarChar(36)
  username                 String   @unique @db.VarChar(50)
  phoneNumber              String?  @map("phone_number") @db.VarChar(32)
  avatarUrl                String?  @map("avatar_url") @db.VarChar(2048)
  avatarBlobName           String?  @map("avatar_blob_name") @db.VarChar(1024)
  isPrivate                Boolean  @default(false) @map("is_private")
  trustworthinessScore     Int      @default(1) @map("trustworthiness_score")
  rentPostingsCount        Int      @default(0) @map("rent_postings_count")
  availableRentPostingsCount Int    @default(0) @map("available_rent_postings_count")
  createdAt                DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt                DateTime @updatedAt @map("updated_at") @db.DateTime(6)
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("profiles")
}

model Device {
  id            String   @id @db.VarChar(36)
  userId        String   @map("user_id") @db.VarChar(36)
  deviceId      String   @map("device_id") @db.VarChar(255)
  type          String   @db.VarChar(50)
  platform      String?  @db.VarChar(255)
  userAgent     String?  @map("user_agent") @db.VarChar(1024)
  lastIpAddress String?  @map("last_ip_address") @db.VarChar(255)
  firstSeenAt   DateTime @default(now()) @map("first_seen_at") @db.DateTime(6)
  lastSeenAt    DateTime @default(now()) @map("last_seen_at") @db.DateTime(6)
  verifiedAt    DateTime @default(now()) @map("verified_at") @db.DateTime(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.DateTime(6)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("devices")
}

model Posting {
  id                String                     @id @db.VarChar(36)
  ownerId           String                     @map("owner_id") @db.VarChar(36)
  status            PostingStatus
  name              String                     @db.VarChar(150)
  description       String                     @db.Text
  pricingCurrency   String                     @map("pricing_currency") @db.VarChar(3)
  pricing           Json
  tags              Json
  attributes        Json
  availabilityStatus PostingAvailabilityStatus @map("availability_status")
  availabilityNotes String?                    @map("availability_notes") @db.VarChar(500)
  latitude          Float
  longitude         Float
  city              String                     @db.VarChar(120)
  region            String                     @db.VarChar(120)
  country           String                     @db.VarChar(120)
  postalCode        String?                    @map("postal_code") @db.VarChar(32)
  publishedAt       DateTime?                  @map("published_at") @db.DateTime(6)
  archivedAt        DateTime?                  @map("archived_at") @db.DateTime(6)
  createdAt         DateTime                   @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt         DateTime                   @updatedAt @map("updated_at") @db.DateTime(6)
  owner             User                       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  photos            PostingPhoto[]
  availabilityBlocks PostingAvailabilityBlock[]
  searchOutboxEntries PostingSearchOutbox[]
  viewEvents        PostingViewEvent[]
  hourlyAnalytics   PostingAnalyticsHourly[]
  dailyAnalytics    PostingAnalyticsDaily[]
  analyticsOutboxEntries PostingAnalyticsOutbox[]
  reviews           PostingReview[]

  @@index([ownerId, status])
  @@index([status, publishedAt])
  @@index([country, region, city])
  @@map("postings")
}

model PostingPhoto {
  id         String   @id @db.VarChar(36)
  postingId  String   @map("posting_id") @db.VarChar(36)
  blobUrl    String   @map("blob_url") @db.VarChar(2048)
  blobName   String   @map("blob_name") @db.VarChar(1024)
  position   Int
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.DateTime(6)
  posting    Posting  @relation(fields: [postingId], references: [id], onDelete: Cascade)

  @@unique([postingId, position])
  @@index([postingId])
  @@map("posting_photos")
}

model PostingAvailabilityBlock {
  id         String   @id @db.VarChar(36)
  postingId  String   @map("posting_id") @db.VarChar(36)
  startAt    DateTime @map("start_at") @db.DateTime(6)
  endAt      DateTime @map("end_at") @db.DateTime(6)
  note       String?  @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.DateTime(6)
  posting    Posting  @relation(fields: [postingId], references: [id], onDelete: Cascade)

  @@index([postingId, startAt, endAt])
  @@map("posting_availability_blocks")
}

model PostingSearchOutbox {
  id           String                     @id @db.VarChar(36)
  postingId    String                     @map("posting_id") @db.VarChar(36)
  operation    PostingSearchOutboxOperation
  attempts     Int                        @default(0)
  availableAt  DateTime                   @default(now()) @map("available_at") @db.DateTime(6)
  processingAt DateTime?                  @map("processing_at") @db.DateTime(6)
  processedAt  DateTime?                  @map("processed_at") @db.DateTime(6)
  lastError    String?                    @map("last_error") @db.VarChar(2048)
  createdAt    DateTime                   @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt    DateTime                   @updatedAt @map("updated_at") @db.DateTime(6)
  posting      Posting                    @relation(fields: [postingId], references: [id], onDelete: Cascade)

  @@index([availableAt, processedAt, processingAt])
  @@index([postingId, operation])
  @@map("posting_search_outbox")
}

model PostingViewEvent {
  id             String   @id @db.VarChar(36)
  postingId      String   @map("posting_id") @db.VarChar(36)
  ownerId        String   @map("owner_id") @db.VarChar(36)
  viewerHash     String   @map("viewer_hash") @db.VarChar(128)
  userId         String?  @map("user_id") @db.VarChar(36)
  ipAddressHash  String?  @map("ip_address_hash") @db.VarChar(128)
  userAgentHash  String?  @map("user_agent_hash") @db.VarChar(128)
  deviceType     String   @map("device_type") @db.VarChar(32)
  occurredAt     DateTime @map("occurred_at") @db.DateTime(6)
  eventDate      DateTime @map("event_date") @db.DateTime(6)
  eventHour      DateTime @map("event_hour") @db.DateTime(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(6)
  posting        Posting  @relation(fields: [postingId], references: [id], onDelete: Cascade)

  @@index([postingId, eventDate])
  @@index([ownerId, eventDate])
  @@index([postingId, eventHour])
  @@index([viewerHash, eventDate])
  @@map("posting_view_events")
}

model PostingAnalyticsUniqueView {
  postingId   String   @map("posting_id") @db.VarChar(36)
  ownerId     String   @map("owner_id") @db.VarChar(36)
  viewerHash  String   @map("viewer_hash") @db.VarChar(128)
  eventDate   DateTime @map("event_date") @db.DateTime(6)
  firstSeenAt DateTime @default(now()) @map("first_seen_at") @db.DateTime(6)

  @@id([postingId, eventDate, viewerHash])
  @@index([ownerId, eventDate])
  @@map("posting_analytics_unique_views")
}

model PostingAnalyticsHourly {
  id               String   @id @db.VarChar(36)
  postingId        String   @map("posting_id") @db.VarChar(36)
  ownerId          String   @map("owner_id") @db.VarChar(36)
  bucketStart      DateTime @map("bucket_start") @db.DateTime(6)
  views            Int      @default(0)
  uniqueViews      Int      @default(0) @map("unique_views")
  bookingRequests  Int      @default(0) @map("booking_requests")
  estimatedRevenue Decimal  @default(0) @map("estimated_revenue") @db.Decimal(18, 2)
  createdAt        DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.DateTime(6)
  posting          Posting  @relation(fields: [postingId], references: [id], onDelete: Cascade)

  @@unique([postingId, bucketStart])
  @@index([ownerId, bucketStart])
  @@map("posting_analytics_hourly")
}

model PostingAnalyticsDaily {
  id               String   @id @db.VarChar(36)
  postingId        String   @map("posting_id") @db.VarChar(36)
  ownerId          String   @map("owner_id") @db.VarChar(36)
  bucketStart      DateTime @map("bucket_start") @db.DateTime(6)
  views            Int      @default(0)
  uniqueViews      Int      @default(0) @map("unique_views")
  bookingRequests  Int      @default(0) @map("booking_requests")
  estimatedRevenue Decimal  @default(0) @map("estimated_revenue") @db.Decimal(18, 2)
  createdAt        DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.DateTime(6)
  posting          Posting  @relation(fields: [postingId], references: [id], onDelete: Cascade)

  @@unique([postingId, bucketStart])
  @@index([ownerId, bucketStart])
  @@map("posting_analytics_daily")
}

model PostingAnalyticsOutbox {
  id           String                    @id @db.VarChar(36)
  postingId    String                    @map("posting_id") @db.VarChar(36)
  ownerId      String                    @map("owner_id") @db.VarChar(36)
  eventType    PostingAnalyticsEventType @map("event_type")
  payload      Json
  attempts     Int                       @default(0)
  availableAt  DateTime                  @default(now()) @map("available_at") @db.DateTime(6)
  processingAt DateTime?                 @map("processing_at") @db.DateTime(6)
  processedAt  DateTime?                 @map("processed_at") @db.DateTime(6)
  lastError    String?                   @map("last_error") @db.VarChar(2048)
  createdAt    DateTime                  @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt    DateTime                  @updatedAt @map("updated_at") @db.DateTime(6)
  posting      Posting                   @relation(fields: [postingId], references: [id], onDelete: Cascade)

  @@index([availableAt, processedAt, processingAt])
  @@index([ownerId, eventType])
  @@index([postingId, eventType])
  @@map("posting_analytics_outbox")
}

model PostingReview {
  id         String   @id @db.VarChar(36)
  postingId  String   @map("posting_id") @db.VarChar(36)
  reviewerId String   @map("reviewer_id") @db.VarChar(36)
  rating     Int
  title      String?  @db.VarChar(120)
  comment    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.DateTime(6)
  posting    Posting  @relation(fields: [postingId], references: [id], onDelete: Cascade)
  reviewer   User     @relation("PostingReviewAuthor", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([postingId, reviewerId])
  @@index([postingId, createdAt])
  @@index([reviewerId])
  @@map("posting_reviews")
}

enum PostingStatus {
  draft
  published
  archived
}

enum PostingAvailabilityStatus {
  available
  limited
  unavailable
}

enum PostingSearchOutboxOperation {
  upsert
  delete
}

enum PostingAnalyticsEventType {
  posting_viewed
  booking_requested
  booking_accepted
  payment_captured
}

