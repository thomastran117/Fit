generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @db.VarChar(36)
  email         String   @unique @db.VarChar(255)
  passwordHash  String?  @map("password_hash") @db.VarChar(255)
  tokenVersion  Int      @default(0) @map("token_version")
  firstName     String?  @map("first_name") @db.VarChar(255)
  lastName      String?  @map("last_name") @db.VarChar(255)
  role          String   @db.VarChar(50)
  emailVerified Boolean  @default(false) @map("email_verified")
  createdAt     DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.DateTime(6)
  devices       Device[]
  oauthIdentities OAuthIdentity[]
  profile       Profile?
  postings      Posting[]
  postingReviews PostingReview[] @relation("PostingReviewAuthor")
  bookingRequestsAsRenter BookingRequest[] @relation("BookingRequestRenter")
  bookingRequestsAsOwner  BookingRequest[] @relation("BookingRequestOwner")
  rentingsAsRenter Renting[] @relation("RentingRenter")
  rentingsAsOwner  Renting[] @relation("RentingOwner")
  paymentsAsRenter Payment[] @relation("PaymentRenter")
  paymentsAsOwner  Payment[] @relation("PaymentOwner")
  payouts          Payout[]
  refundsIssued    Refund[]  @relation("RefundIssuer")
  personalAccessTokens PersonalAccessToken[]

  @@map("users")
}

model PersonalAccessToken {
  id          String   @id @db.VarChar(36)
  userId      String   @map("user_id") @db.VarChar(36)
  name        String   @db.VarChar(120)
  publicId    String   @unique @map("public_id") @db.VarChar(32)
  tokenPrefix String   @map("token_prefix") @db.VarChar(64)
  secretHash  String   @map("secret_hash") @db.VarChar(255)
  scopes      Json
  lastUsedAt  DateTime? @map("last_used_at") @db.DateTime(6)
  expiresAt   DateTime? @map("expires_at") @db.DateTime(6)
  revokedAt   DateTime? @map("revoked_at") @db.DateTime(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime(6)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([publicId])
  @@map("personal_access_tokens")
}

model OAuthIdentity {
  id             String   @id @db.VarChar(36)
  userId         String   @map("user_id") @db.VarChar(36)
  provider       String   @db.VarChar(50)
  providerUserId String   @map("provider_user_id") @db.VarChar(255)
  providerEmail  String?  @map("provider_email") @db.VarChar(255)
  emailVerified  Boolean  @default(false) @map("email_verified")
  displayName    String?  @map("display_name") @db.VarChar(255)
  linkedAt       DateTime @default(now()) @map("linked_at") @db.DateTime(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.DateTime(6)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([userId])
  @@map("oauth_identities")
}

model Profile {
  id                       String   @id @db.VarChar(36)
  userId                   String   @unique @map("user_id") @db.VarChar(36)
  username                 String   @unique @db.VarChar(50)
  phoneNumber              String?  @map("phone_number") @db.VarChar(32)
  avatarUrl                String?  @map("avatar_url") @db.VarChar(2048)
  avatarBlobName           String?  @map("avatar_blob_name") @db.VarChar(1024)
  isPrivate                Boolean  @default(false) @map("is_private")
  recommendationPersonalizationEnabled Boolean @default(true) @map("recommendation_personalization_enabled")
  trustworthinessScore     Int      @default(1) @map("trustworthiness_score")
  rentPostingsCount        Int      @default(0) @map("rent_postings_count")
  availableRentPostingsCount Int    @default(0) @map("available_rent_postings_count")
  createdAt                DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt                DateTime @updatedAt @map("updated_at") @db.DateTime(6)
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("profiles")
}

model Device {
  id            String   @id @db.VarChar(36)
  userId        String   @map("user_id") @db.VarChar(36)
  deviceId      String   @map("device_id") @db.VarChar(255)
  type          String   @db.VarChar(50)
  platform      String?  @db.VarChar(255)
  userAgent     String?  @map("user_agent") @db.VarChar(1024)
  lastIpAddress String?  @map("last_ip_address") @db.VarChar(255)
  firstSeenAt   DateTime @default(now()) @map("first_seen_at") @db.DateTime(6)
  lastSeenAt    DateTime @default(now()) @map("last_seen_at") @db.DateTime(6)
  verifiedAt    DateTime @default(now()) @map("verified_at") @db.DateTime(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.DateTime(6)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("devices")
}

model Posting {
  id                String                     @id @db.VarChar(36)
  ownerId           String                     @map("owner_id") @db.VarChar(36)
  status            PostingStatus
  family            PostingFamily
  subtype           String                     @db.VarChar(50)
  name              String                     @db.VarChar(150)
  description       String                     @db.Text
  pricingCurrency   String                     @map("pricing_currency") @db.VarChar(3)
  pricing           Json
  tags              Json
  attributes        Json
  availabilityStatus PostingAvailabilityStatus @map("availability_status")
  availabilityNotes String?                    @map("availability_notes") @db.VarChar(500)
  maxBookingDurationDays Int?                  @map("max_booking_duration_days")
  latitude          Float
  longitude         Float
  city              String                     @db.VarChar(120)
  region            String                     @db.VarChar(120)
  country           String                     @db.VarChar(120)
  postalCode        String?                    @map("postal_code") @db.VarChar(32)
  publishedAt       DateTime?                  @map("published_at") @db.DateTime(6)
  pausedAt          DateTime?                  @map("paused_at") @db.DateTime(6)
  archivedAt        DateTime?                  @map("archived_at") @db.DateTime(6)
  createdAt         DateTime                   @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt         DateTime                   @updatedAt @map("updated_at") @db.DateTime(6)
  owner             User                       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  photos            PostingPhoto[]
  availabilityBlocks PostingAvailabilityBlock[]
  searchOutboxEntries PostingSearchOutbox[]
  viewEvents        PostingViewEvent[]
  recommendationActivities RecommendationActivity[]
  hourlyAnalytics   PostingAnalyticsHourly[]
  dailyAnalytics    PostingAnalyticsDaily[]
  analyticsOutboxEntries PostingAnalyticsOutbox[]
  reviews           PostingReview[]
  bookingRequests   BookingRequest[]
  rentings          Renting[]
  payments          Payment[]

  @@index([ownerId, status])
  @@index([status, publishedAt])
  @@index([status, family, subtype, publishedAt])
  @@index([country, region, city])
  @@map("postings")
}

model PostingPhoto {
  id         String   @id @db.VarChar(36)
  postingId  String   @map("posting_id") @db.VarChar(36)
  blobUrl    String   @map("blob_url") @db.VarChar(2048)
  blobName   String   @map("blob_name") @db.VarChar(1024)
  position   Int
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.DateTime(6)
  posting    Posting  @relation(fields: [postingId], references: [id], onDelete: Cascade)

  @@unique([postingId, position])
  @@index([postingId])
  @@map("posting_photos")
}

model PostingAvailabilityBlock {
  id         String   @id @db.VarChar(36)
  postingId  String   @map("posting_id") @db.VarChar(36)
  startAt    DateTime @map("start_at") @db.DateTime(6)
  endAt      DateTime @map("end_at") @db.DateTime(6)
  note       String?  @db.VarChar(255)
  source     PostingAvailabilityBlockSource @default(owner)
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.DateTime(6)
  posting    Posting  @relation(fields: [postingId], references: [id], onDelete: Cascade)
  bookingRequestHold BookingRequest? @relation("BookingRequestHold")

  @@index([postingId, source, startAt, endAt])
  @@index([postingId, startAt, endAt])
  @@map("posting_availability_blocks")
}

model BookingRequest {
  id             String               @id @db.VarChar(36)
  postingId       String               @map("posting_id") @db.VarChar(36)
  renterId        String               @map("renter_id") @db.VarChar(36)
  ownerId         String               @map("owner_id") @db.VarChar(36)
  status          BookingRequestStatus
  startAt         DateTime             @map("start_at") @db.DateTime(6)
  endAt           DateTime             @map("end_at") @db.DateTime(6)
  durationDays    Int                  @map("duration_days")
  guestCount      Int                  @map("guest_count")
  contactName     String               @map("contact_name") @db.VarChar(255)
  contactEmail    String               @map("contact_email") @db.VarChar(255)
  contactPhoneNumber String?           @map("contact_phone_number") @db.VarChar(32)
  note            String?              @db.VarChar(1000)
  pricingCurrency String               @map("pricing_currency") @db.VarChar(3)
  pricingSnapshot Json                 @map("pricing_snapshot")
  dailyPriceAmount Decimal             @map("daily_price_amount") @db.Decimal(18, 2)
  estimatedTotal  Decimal              @map("estimated_total") @db.Decimal(18, 2)
  decisionNote    String?              @map("decision_note") @db.VarChar(1000)
  approvedAt      DateTime?            @map("approved_at") @db.DateTime(6)
  paymentRequiredAt DateTime?          @map("payment_required_at") @db.DateTime(6)
  paymentFailedAt DateTime?            @map("payment_failed_at") @db.DateTime(6)
  cancelledAt     DateTime?            @map("cancelled_at") @db.DateTime(6)
  refundedAt      DateTime?            @map("refunded_at") @db.DateTime(6)
  declinedAt      DateTime?            @map("declined_at") @db.DateTime(6)
  expiredAt       DateTime?            @map("expired_at") @db.DateTime(6)
  convertedAt     DateTime?            @map("converted_at") @db.DateTime(6)
  conversionReservedAt DateTime?       @map("conversion_reserved_at") @db.DateTime(6)
  conversionReservationExpiresAt DateTime? @map("conversion_reservation_expires_at") @db.DateTime(6)
  holdExpiresAt   DateTime             @map("hold_expires_at") @db.DateTime(6)
  holdBlockId     String?              @unique @map("hold_block_id") @db.VarChar(36)
  paymentReconciliationRequired Boolean @default(false) @map("payment_reconciliation_required")
  createdAt       DateTime             @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.DateTime(6)
  posting         Posting              @relation(fields: [postingId], references: [id], onDelete: Cascade)
  renter          User                 @relation("BookingRequestRenter", fields: [renterId], references: [id], onDelete: Cascade)
  owner           User                 @relation("BookingRequestOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  holdBlock       PostingAvailabilityBlock? @relation("BookingRequestHold", fields: [holdBlockId], references: [id], onDelete: SetNull)
  renting         Renting?
  payment         Payment?

  @@index([postingId, status, startAt])
  @@index([postingId, holdExpiresAt])
  @@index([status, conversionReservationExpiresAt])
  @@index([ownerId, status, createdAt])
  @@index([renterId, status, createdAt])
  @@index([status, holdExpiresAt])
  @@map("booking_requests")
}

model Renting {
  id               String        @id @db.VarChar(36)
  postingId         String        @map("posting_id") @db.VarChar(36)
  bookingRequestId  String        @unique @map("booking_request_id") @db.VarChar(36)
  renterId          String        @map("renter_id") @db.VarChar(36)
  ownerId           String        @map("owner_id") @db.VarChar(36)
  status            RentingStatus
  startAt           DateTime      @map("start_at") @db.DateTime(6)
  endAt             DateTime      @map("end_at") @db.DateTime(6)
  durationDays      Int           @map("duration_days")
  guestCount        Int           @map("guest_count")
  pricingCurrency   String        @map("pricing_currency") @db.VarChar(3)
  pricingSnapshot   Json          @map("pricing_snapshot")
  dailyPriceAmount  Decimal       @map("daily_price_amount") @db.Decimal(18, 2)
  estimatedTotal    Decimal       @map("estimated_total") @db.Decimal(18, 2)
  confirmedAt       DateTime      @map("confirmed_at") @db.DateTime(6)
  createdAt         DateTime      @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.DateTime(6)
  posting           Posting       @relation(fields: [postingId], references: [id], onDelete: Cascade)
  bookingRequest    BookingRequest @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)
  renter            User          @relation("RentingRenter", fields: [renterId], references: [id], onDelete: Cascade)
  owner             User          @relation("RentingOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([postingId, status, startAt])
  @@index([renterId, status, createdAt])
  @@index([ownerId, status, createdAt])
  @@map("rentings")
}

model Payment {
  id                   String         @id @db.VarChar(36)
  bookingRequestId     String         @unique @map("booking_request_id") @db.VarChar(36)
  postingId            String         @map("posting_id") @db.VarChar(36)
  renterId             String         @map("renter_id") @db.VarChar(36)
  ownerId              String         @map("owner_id") @db.VarChar(36)
  provider             PaymentProvider
  status               PaymentStatus
  pricingCurrency      String         @map("pricing_currency") @db.VarChar(3)
  rentalSubtotalAmount Decimal        @map("rental_subtotal_amount") @db.Decimal(18, 2)
  platformFeeAmount    Decimal        @map("platform_fee_amount") @db.Decimal(18, 2)
  totalAmount          Decimal        @map("total_amount") @db.Decimal(18, 2)
  squarePaymentId      String?        @unique @map("square_payment_id") @db.VarChar(128)
  squareOrderId        String?        @unique @map("square_order_id") @db.VarChar(128)
  squareLocationId     String?        @map("square_location_id") @db.VarChar(128)
  checkoutUrl          String?        @map("checkout_url") @db.VarChar(2048)
  lastAttemptedAt      DateTime?      @map("last_attempted_at") @db.DateTime(6)
  succeededAt          DateTime?      @map("succeeded_at") @db.DateTime(6)
  failedAt             DateTime?      @map("failed_at") @db.DateTime(6)
  cancelledAt          DateTime?      @map("cancelled_at") @db.DateTime(6)
  createdAt            DateTime       @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt            DateTime       @updatedAt @map("updated_at") @db.DateTime(6)
  bookingRequest       BookingRequest @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)
  posting              Posting        @relation(fields: [postingId], references: [id], onDelete: Cascade)
  renter               User           @relation("PaymentRenter", fields: [renterId], references: [id], onDelete: Cascade)
  owner                User           @relation("PaymentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  attempts             PaymentAttempt[]
  refunds              Refund[]
  payout               Payout?
  webhookEvents        PaymentWebhookEvent[]
  ledgerEntries        PaymentLedgerEntry[]

  @@index([renterId, status, createdAt])
  @@index([ownerId, status, createdAt])
  @@index([status, createdAt])
  @@map("payments")
}

model PaymentAttempt {
  id                String                  @id @db.VarChar(36)
  paymentId         String                  @map("payment_id") @db.VarChar(36)
  idempotencyKey    String                  @unique @map("idempotency_key") @db.VarChar(255)
  status            PaymentAttemptStatus
  retryCount        Int                     @default(0) @map("retry_count")
  failureCategory   PaymentFailureCategory? @map("failure_category")
  failureCode       String?                 @map("failure_code") @db.VarChar(255)
  failureMessage    String?                 @map("failure_message") @db.VarChar(2048)
  providerRequestId String?                 @map("provider_request_id") @db.VarChar(255)
  squarePaymentId   String?                 @map("square_payment_id") @db.VarChar(128)
  requestPayload    Json?                   @map("request_payload")
  responsePayload   Json?                   @map("response_payload")
  nextRetryAt       DateTime?               @map("next_retry_at") @db.DateTime(6)
  createdAt         DateTime                @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt         DateTime                @updatedAt @map("updated_at") @db.DateTime(6)
  payment           Payment                 @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@index([status, nextRetryAt])
  @@map("payment_attempts")
}

model Refund {
  id             String       @id @db.VarChar(36)
  paymentId      String       @map("payment_id") @db.VarChar(36)
  issuedByUserId String?      @map("issued_by_user_id") @db.VarChar(36)
  status         RefundStatus
  amount         Decimal      @db.Decimal(18, 2)
  reason         String?      @db.VarChar(1000)
  idempotencyKey String       @unique @map("idempotency_key") @db.VarChar(255)
  squareRefundId String?      @unique @map("square_refund_id") @db.VarChar(128)
  createdAt      DateTime     @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.DateTime(6)
  completedAt    DateTime?    @map("completed_at") @db.DateTime(6)
  payment        Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  issuedBy       User?        @relation("RefundIssuer", fields: [issuedByUserId], references: [id], onDelete: SetNull)

  @@index([paymentId, createdAt])
  @@map("refunds")
}

model Payout {
  id             String       @id @db.VarChar(36)
  paymentId      String       @unique @map("payment_id") @db.VarChar(36)
  ownerId        String       @map("owner_id") @db.VarChar(36)
  status         PayoutStatus
  amount         Decimal      @db.Decimal(18, 2)
  dueAt          DateTime     @map("due_at") @db.DateTime(6)
  releasedAt     DateTime?    @map("released_at") @db.DateTime(6)
  failedAt       DateTime?    @map("failed_at") @db.DateTime(6)
  squarePayoutId String?      @unique @map("square_payout_id") @db.VarChar(128)
  failureMessage String?      @map("failure_message") @db.VarChar(2048)
  createdAt      DateTime     @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.DateTime(6)
  payment        Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  owner          User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, status, dueAt])
  @@index([status, dueAt])
  @@map("payouts")
}

model PaymentWebhookEvent {
  id              String          @id @db.VarChar(36)
  paymentId       String?         @map("payment_id") @db.VarChar(36)
  provider        PaymentProvider
  providerEventId String          @unique @map("provider_event_id") @db.VarChar(255)
  eventType       String          @map("event_type") @db.VarChar(255)
  signatureValid  Boolean         @map("signature_valid")
  rawPayload      Json            @map("raw_payload")
  processedAt     DateTime?       @map("processed_at") @db.DateTime(6)
  createdAt       DateTime        @default(now()) @map("created_at") @db.DateTime(6)
  payment         Payment?        @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([provider, eventType, createdAt])
  @@map("payment_webhook_events")
}

model PaymentLedgerEntry {
  id        String                 @id @db.VarChar(36)
  paymentId String                 @map("payment_id") @db.VarChar(36)
  type      PaymentLedgerEntryType
  amount    Decimal                @db.Decimal(18, 2)
  currency  String                 @db.VarChar(3)
  metadata  Json?
  createdAt DateTime               @default(now()) @map("created_at") @db.DateTime(6)
  payment   Payment                @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@index([type, createdAt])
  @@map("payment_ledger_entries")
}

model PostingSearchOutbox {
  id           String                     @id @db.VarChar(36)
  postingId    String?                    @map("posting_id") @db.VarChar(36)
  reindexRunId String?                    @map("reindex_run_id") @db.VarChar(36)
  operation    PostingSearchOutboxOperation
  dedupeKey    String                     @map("dedupe_key") @db.VarChar(255)
  targetIndexName String?                 @map("target_index_name") @db.VarChar(191)
  attempts     Int                        @default(0)
  publishAttempts Int                     @default(0) @map("publish_attempts")
  availableAt  DateTime                   @default(now()) @map("available_at") @db.DateTime(6)
  processingAt DateTime?                  @map("processing_at") @db.DateTime(6)
  processedAt  DateTime?                  @map("processed_at") @db.DateTime(6)
  indexedAt    DateTime?                  @map("indexed_at") @db.DateTime(6)
  deadLetteredAt DateTime?                @map("dead_lettered_at") @db.DateTime(6)
  brokerMessageId String?                 @map("broker_message_id") @db.VarChar(255)
  lastError    String?                    @map("last_error") @db.VarChar(2048)
  createdAt    DateTime                   @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt    DateTime                   @updatedAt @map("updated_at") @db.DateTime(6)
  posting      Posting?                   @relation(fields: [postingId], references: [id], onDelete: Cascade)
  reindexRun   SearchReindexRun?          @relation(fields: [reindexRunId], references: [id], onDelete: SetNull)

  @@index([availableAt, processedAt, deadLetteredAt, processingAt], map: "ps_outbox_ready_idx")
  @@index([postingId, operation])
  @@index([reindexRunId, indexedAt, deadLetteredAt], map: "ps_outbox_reindex_idx")
  @@index([targetIndexName, indexedAt, deadLetteredAt], map: "ps_outbox_target_idx")
  @@map("posting_search_outbox")
}

model SearchReindexRun {
  id               String              @id @db.VarChar(36)
  status           SearchReindexStatus
  targetIndexName  String              @map("target_index_name") @db.VarChar(191)
  retainedIndexName String?            @map("retained_index_name") @db.VarChar(191)
  sourceSnapshotAt DateTime            @map("source_snapshot_at") @db.DateTime(6)
  barrierOutboxId  String?             @unique @map("barrier_outbox_id") @db.VarChar(36)
  totalPostings    Int                 @default(0) @map("total_postings")
  indexedPostings  Int                 @default(0) @map("indexed_postings")
  failedPostings   Int                 @default(0) @map("failed_postings")
  startedAt        DateTime?           @map("started_at") @db.DateTime(6)
  completedAt      DateTime?           @map("completed_at") @db.DateTime(6)
  failedAt         DateTime?           @map("failed_at") @db.DateTime(6)
  processingAt     DateTime?           @map("processing_at") @db.DateTime(6)
  lastError        String?             @map("last_error") @db.VarChar(2048)
  createdAt        DateTime            @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt        DateTime            @updatedAt @map("updated_at") @db.DateTime(6)
  outboxEntries    PostingSearchOutbox[]

  @@index([status, createdAt])
  @@index([processingAt, status])
  @@map("search_reindex_runs")
}

model PostingViewEvent {
  id             String   @id @db.VarChar(36)
  postingId      String   @map("posting_id") @db.VarChar(36)
  ownerId        String   @map("owner_id") @db.VarChar(36)
  viewerHash     String   @map("viewer_hash") @db.VarChar(128)
  userId         String?  @map("user_id") @db.VarChar(36)
  ipAddressHash  String?  @map("ip_address_hash") @db.VarChar(128)
  userAgentHash  String?  @map("user_agent_hash") @db.VarChar(128)
  deviceType     String   @map("device_type") @db.VarChar(32)
  occurredAt     DateTime @map("occurred_at") @db.DateTime(6)
  eventDate      DateTime @map("event_date") @db.DateTime(6)
  eventHour      DateTime @map("event_hour") @db.DateTime(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(6)
