model RecommendationActivity {
  id                       String                          @id @db.VarChar(36)
  aggregationKey           String                          @unique @map("aggregation_key") @db.VarChar(255)
  eventType                RecommendationActivityEventType @map("event_type")
  source                   RecommendationActivitySource
  occurredAt               DateTime                        @map("occurred_at") @db.DateTime(6)
  postingId                String                          @map("posting_id") @db.VarChar(36)
  ownerId                  String                          @map("owner_id") @db.VarChar(36)
  actorUserId              String?                         @map("actor_user_id") @db.VarChar(36)
  anonymousActorHash       String?                         @map("anonymous_actor_hash") @db.VarChar(128)
  deviceType               String                          @map("device_type") @db.VarChar(32)
  requestId                String?                         @map("request_id") @db.VarChar(255)
  searchSessionId          String?                         @map("search_session_id") @db.VarChar(255)
  metadata                 Json?
  count                    Int                             @default(1)
  firstOccurredAt          DateTime                        @map("first_occurred_at") @db.DateTime(6)
  lastOccurredAt           DateTime                        @map("last_occurred_at") @db.DateTime(6)
  personalizationEligible  Boolean                         @default(false) @map("personalization_eligible")
  createdAt                DateTime                        @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt                DateTime                        @updatedAt @map("updated_at") @db.DateTime(6)
  posting                  Posting                         @relation(fields: [postingId], references: [id], onDelete: Cascade)

  @@index([postingId, eventType, lastOccurredAt])
  @@index([actorUserId, personalizationEligible, lastOccurredAt])
  @@index([anonymousActorHash, eventType, lastOccurredAt])
  @@index([ownerId, eventType, lastOccurredAt])
  @@map("recommendation_activities")
}

model RecommendationRefreshJob {
  id           String                          @id @db.VarChar(36)
  jobType      RecommendationRefreshJobType    @map("job_type")
  dedupeKey    String                          @unique @map("dedupe_key") @db.VarChar(255)
  userId       String?                         @map("user_id") @db.VarChar(36)
  segmentType  RecommendationPopularSegmentType? @map("segment_type")
  segmentValue String?                         @map("segment_value") @db.VarChar(191)
  availableAt  DateTime                        @default(now()) @map("available_at") @db.DateTime(6)
  processingAt DateTime?                       @map("processing_at") @db.DateTime(6)
  processedAt  DateTime?                       @map("processed_at") @db.DateTime(6)
  attempts     Int                             @default(0)
  lastError    String?                         @map("last_error") @db.VarChar(2048)
  createdAt    DateTime                        @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt    DateTime                        @updatedAt @map("updated_at") @db.DateTime(6)

  @@index([availableAt, processedAt, processingAt], map: "recommendation_refresh_jobs_ready_idx")
  @@index([jobType, userId])
  @@index([jobType, segmentType, segmentValue])
  @@map("recommendation_refresh_jobs")
}

