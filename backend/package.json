{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/app/server.ts",
    "seed": "tsx src/app/scripts/seed.ts",
    "seed:dev": "tsx src/app/scripts/seed.ts",
    "seed:refresh": "tsx src/app/scripts/seed.ts --refresh",
    "dev:analytics-worker": "tsx watch src/app/workers/analytics/postings-analytics.worker.ts",
    "dev:booking-expiry-worker": "tsx watch src/app/workers/bookings/booking-expiry.worker.ts",
    "dev:email-worker": "tsx watch src/app/workers/email/email-delivery.worker.ts",
    "dev:payment-repair-worker": "tsx watch src/app/workers/payments/payment-repair.worker.ts",
    "dev:payment-retry-worker": "tsx watch src/app/workers/payments/payment-retry.worker.ts",
    "dev:payout-release-worker": "tsx watch src/app/workers/payments/payout-release.worker.ts",
    "dev:search-worker": "tsx watch src/app/workers/search/search-outbox-relay.worker.ts",
    "dev:search-outbox-relay-worker": "tsx watch src/app/workers/search/search-outbox-relay.worker.ts",
    "dev:search-indexer-worker": "tsx watch src/app/workers/search/search-indexer.worker.ts",
    "dev:search-reconcile-worker": "tsx watch src/app/workers/search/search-reconcile.worker.ts",
    "dev:search-reindex-worker": "tsx watch src/app/workers/search/search-reindex.worker.ts",
    "build": "tsup src/app/server.ts src/app/scripts/seed.ts src/app/workers/analytics/postings-analytics.worker.ts src/app/workers/bookings/booking-expiry.worker.ts src/app/workers/email/email-delivery.worker.ts src/app/workers/payments/payment-retry.worker.ts src/app/workers/payments/payment-repair.worker.ts src/app/workers/payments/payout-release.worker.ts src/app/workers/search/search-outbox-relay.worker.ts src/app/workers/search/search-indexer.worker.ts src/app/workers/search/search-reconcile.worker.ts src/app/workers/search/search-reindex.worker.ts --format esm --platform node --target node22 --out-dir dist --clean",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "start": "node dist/server.js",
    "check": "tsc --noEmit --project tsconfig.json",
    "test": "jest --config jest.config.cjs --runInBand",
    "test:db-seeds": "jest --config jest.db-seeds.config.cjs --runInBand"
  },
  "prisma": {
    "seed": "tsx src/app/scripts/seed.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@hono/node-server": "^1.19.4",
    "@prisma/client": "^6.7.0",
    "amqplib": "^1.0.3",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "hono": "^4.9.8",
    "mysql2": "^3.15.2",
    "nodemailer": "^8.0.5",
    "redis": "^5.8.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "jest": "^30.3.0",
    "prisma": "^6.7.0",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
